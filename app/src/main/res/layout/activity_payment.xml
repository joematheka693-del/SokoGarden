<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#66F2CFAF"
    tools:context=".PaymentActivity">

<!--    Below is a Textview-->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Complete Payment with M-pesa"
        android:textStyle="italic|bold"
        android:textSize="32sp"
        android:textAlignment="center"
        android:fontFamily="times new roman"
        android:textColor="#00ED00"
        android:layout_marginTop="10dp" />

<!--    Below is a cardview that holds all our contents-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardElevation="12dp"
        app:cardCornerRadius="15dp"
        android:padding="10dp">

<!--        Below is a LinearLayout-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#6449" >

<!--            Below is a TextView where the name of the Product shall be binded/attached-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductName"
                android:text="Product Name"
                android:textSize="20sp"
                android:textStyle="bold|italic"
                android:fontFamily="times new roman"
                android:textColor="#8320"/>

<!--            Below is an Imageview for the product Image-->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:id="@+id/imgProduct"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:layout_marginTop="10dp"
                android:layout_marginRight="20dp"
                android:layout_marginLeft="20dp"/>

<!--            Below is a Textview for the product cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductCost"
                android:text="Kes 1500"
                android:textSize="20sp"
                android:fontFamily="times new roman"
                android:layout_marginTop="5dp"
                android:textStyle="italic|bold"
                android:textColor="#ae1522" />

<!--            Textview for product description-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductDescription"
                android:text="Product Description"
                android:textSize="20sp"
                android:fontFamily="times new roman"
                android:layout_marginTop="5dp"
                android:textStyle="italic|bold"
                android:textColor="#476733" />




<!--            Below is an EditText to enter mobile number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#c2a32a"
                android:id="@+id/phone"
                android:hint="Enter Mobile Number e.g 25471234...."
                android:textSize="15sp"
                android:textColorHint="#000"
                android:textColor="#000"
                android:fontFamily="times new roman"
                android:textStyle="italic"
                android:padding="15dp"
                android:layout_marginTop="10dp" />

<!--            Below is a button to complete Payment Action-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/pay"
                android:text="Pay Now"
                android:layout_marginTop="25dp"
                android:layout_marginLeft="70dp"
                android:layout_marginRight="70dp"
                android:backgroundTint="#027793"
                android:textColor="#ade97d"
                android:textSize="18sp"
                android:fontFamily="cursive" />



        </LinearLayout>

    </androidx.cardview.widget.CardView>



</LinearLayout>