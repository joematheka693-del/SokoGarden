<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    android:background="#E6FFC77E"
    tools:context=".Signin">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sign In"
        android:textSize="47sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:fontFamily="cursive"
        android:textColor="#181518"
        android:background="@drawable/shape"/>

<!--    Below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="10dp"
        android:layout_margin="10dp"
        android:padding="10dp">

<!--        Below is a linear layout that shall align content vertically-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#845229"
            android:padding="10dp">

<!--            Below is the email EditText     -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧 Enter Email Address"
                android:textColorHint="#77020202"
                android:id="@+id/email"
                android:textColor="@color/black"
                android:layout_margin="8dp"
                android:background="#774A4850"
                android:padding="10dp" />

<!--            Below is the password EditText-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter Your Password"
                android:inputType="textPassword"
                android:textColorHint="#77020202"
                android:id="@+id/password"
                android:textColor="@color/black"
                android:layout_margin="8dp"
                android:background="#774A4850"
                android:padding="10dp" />

<!--            Below is the SignIn Button-->

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" 👤 Signin"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="30dp"
                android:backgroundTint="#446D733C"
                android:textColor="#181518"
                android:fontFamily="cursive"
                android:id="@+id/signinBtn" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/signup_text"
                android:textSize="20sp"
                android:textAlignment="center"
                android:textColor="#027793"
                android:fontFamily="cursive"
                android:id="@+id/signuptxt" />

        </LinearLayout>


    </androidx.cardview.widget.CardView>

</LinearLayout>