<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="#A48943"
    android:layout_height="match_parent"
    tools:context=".Signup">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sign Up"
        android:textSize="38sp"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:fontFamily="times new roman"
        android:textColor="#181518"
        android:background="@drawable/shape"/>

<!--    Below is a cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="10dp"
        android:padding="10dp"
        android:layout_marginTop="15sp"
        android:layout_marginRight="17dp" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp" >

<!--                below is the editText for the username-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤 Enter your username"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:padding="10dp"
                android:background="#848314" />

<!--            Below is the EditText for the Email Address-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧 Enter your Email Address"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/email"
                android:inputType="textEmailAddress"
                android:layout_margin="8dp"
                android:padding="10dp"
                android:background="#848314" />

<!--            Below is the EditText for the Password-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter your Password"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:padding="10dp"
                android:background="#848314" />

<!--            Below is the Editext for phone number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📞 Enter your Phone Number"
                android:textColorHint="@color/black"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/phone"
                android:inputType="number"
                android:layout_margin="8dp"
                android:padding="10dp"
                android:background="#848314" />

<!--            Below is the SignUP Button-->

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" 👤Signup"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="25dp"
                android:backgroundTint="#446D733C"
                android:textColor="#181518"
                android:fontFamily="cursive"
                android:id="@+id/signupBtn" />

            <TextView

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:text="Already Have an Accout? Signin"

                android:textAlignment="center"

                android:textSize="23sp"

                android:fontFamily="cursive"

                android:layout_marginTop="25dp"

                android:textColor="#0013e9"

                android:id="@+id/signintxt" />





        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>